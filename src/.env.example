# =============================================================================
# SafeSnippet Analyzer — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit your .env file to version control!
# =============================================================================

# Google Gemini API Key
# Get yours free at: https://ai.google.dev/gemini-api/docs/api-key
GOOGLE_API_KEY=your_gemini_api_key_here

# Server Configuration
PORT=3000

# Inngest Configuration (optional — defaults work for local development)
# INNGEST_EVENT_KEY=local         # Only needed in production
# INNGEST_SIGNING_KEY=local       # Only needed in production
